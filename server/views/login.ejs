<%- include('partials/head', { title: 'Sign in' }) %>
<main class="gwa-login">
  <form method="post" action="/admin/login" class="gwa-login__card">
    <div class="gwa-login__brand">
      <img class="gwa-brand__mark gwa-brand__mark--img" src="/admin/static/goodway-logo.png" alt="Goodway" width="56" height="56">
      <div>
        <div class="gwa-login__title">Goodway Admin</div>
        <div class="gwa-login__subtitle">Sign in to manage principals, sectors and leads.</div>
      </div>
    </div>
    <%- include('partials/flash') %>
    <input type="hidden" name="_csrf" value="<%= csrf %>">
    <label class="gwa-field">
      <span>Username</span>
      <input type="text" name="username" autocomplete="username" required autofocus>
    </label>
    <label class="gwa-field">
      <span>Password</span>
      <input type="password" name="password" autocomplete="current-password" required>
    </label>
    <button type="submit" class="gwa-btn gwa-btn--primary">Sign in</button>
    <details class="gwa-login__recovery">
      <summary>Forgot password?</summary>
      <p>This admin uses a single account, so password recovery is done from the server shell &mdash; not by email.</p>
      <ol>
        <li>Open a terminal in the <code>server/</code> folder</li>
        <li>Run <code>npm run set-password -- "your-new-password"</code></li>
        <li>Copy the printed <code>ADMIN_PASSWORD_HASH=...</code> line into <code>server/.env</code>, replacing the existing one</li>
        <li>Restart the server (<code>Ctrl + C</code> then <code>npm start</code>)</li>
        <li>Sign in with the new password</li>
      </ol>
      <p>Once signed in, you can change the password anytime from <strong>Profile &rarr; Change password</strong> &mdash; no shell required.</p>
    </details>
  </form>
</main>
</body></html>
