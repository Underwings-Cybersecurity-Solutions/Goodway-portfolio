<%- include('partials/head', { title: 'Change password' }) %>
<div class="gwa-shell">
  <%- include('partials/nav') %>
  <main class="gwa-main">
    <header class="gwa-pagehead">
      <h1>Change password</h1>
      <p class="gwa-sub">Update the admin password. The change takes effect immediately &mdash; no server restart required.</p>
    </header>
    <%- include('partials/flash') %>

    <form method="post" action="/admin/password" class="gwa-form gwa-form--narrow" autocomplete="off">
      <input type="hidden" name="_csrf" value="<%= csrf %>">

      <label class="gwa-field">
        <span>Current password</span>
        <input type="password" name="current_password" autocomplete="current-password" required autofocus>
      </label>

      <label class="gwa-field">
        <span>New password</span>
        <input type="password" name="new_password" autocomplete="new-password" minlength="10" required>
        <small class="gwa-field__hint">At least 10 characters. Mix of letters, numbers and symbols recommended.</small>
      </label>

      <label class="gwa-field">
        <span>Confirm new password</span>
        <input type="password" name="confirm_password" autocomplete="new-password" minlength="10" required>
      </label>

      <div class="gwa-form__actions">
        <button type="submit" class="gwa-btn gwa-btn--primary">Update password</button>
        <a href="/admin" class="gwa-btn gwa-btn--ghost">Cancel</a>
      </div>

      <aside class="gwa-callout gwa-callout--info">
        <strong>What happens when you submit:</strong>
        <ol>
          <li>We verify your current password.</li>
          <li>The new password is hashed with bcrypt (cost 12) and written to <code>server/.env</code>.</li>
          <li>Your existing session stays valid; the next sign-in (yours or anyone else's) requires the new password.</li>
          <li>The change is logged to the audit log.</li>
        </ol>
      </aside>
    </form>
  </main>
</div>
</body></html>
