# Copy to .env and fill in real values. Never commit .env.

# --- Server ---
PORT=4010
NODE_ENV=production                 # enables secure cookies + strict settings
SESSION_SECRET=replace-with-a-long-random-string

# --- Admin credentials ---
# Generate with: npm run set-password -- "your-new-password"
ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH=

# --- Paths ---
SITE_ROOT=..                        # location of the static site, relative to server/

# --- Lead notifications (pick one or more; leave blank to disable) ---
NOTIFY_TO=info@goodway.ae
NOTIFY_FROM=Goodway Website <no-reply@goodway.ae>

# Option A: Resend — https://resend.com (recommended)
RESEND_API_KEY=

# Option B: Postmark — https://postmarkapp.com
POSTMARK_API_KEY=

# Option C: Webhook (Slack, Zapier, Discord, anything that accepts POST JSON)
NOTIFY_WEBHOOK=

# Public admin URL, used for "view lead" links in webhook payload
ADMIN_PUBLIC_URL=https://admin.goodway.ae
